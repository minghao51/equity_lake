# Equity EOD Data Pipeline Configuration
# Prefer the repo-root `.env.example` for the current beta setup.
# This file is kept as a secondary example for compatibility.

# =============================================================================
# AWS Configuration (for S3 sync)
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=s3://your-bucket/path/

# =============================================================================
# Data Configuration
# =============================================================================
DB_PATH=equity_data.duckdb
DATA_DIR=data
LOG_DIR=logs

# =============================================================================
# Market Configuration
# =============================================================================
# Comma-separated list of markets to ingest: us,cn,hk,sg
MARKETS=us,cn,hk,sg

# =============================================================================
# API Retry Configuration
# =============================================================================
# Number of retry attempts for failed API calls (default: 3)
API_RETRY_ATTEMPTS=3

# Base delay between retries in seconds (default: 1.0)
# Exponential backoff: delay * (2^attempt)
# Example with retry_attempts=3, retry_delay=1.0:
#   - Attempt 1: Immediate
#   - Attempt 2: Wait 1s
#   - Attempt 3: Wait 2s
#   - Total max wait: 3 seconds
API_RETRY_DELAY=1.0

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# Development Mode
# =============================================================================
DEV_MODE=false
USE_TEST_DATA=false

# =============================================================================
# Beta Settings Overrides
# =============================================================================
# Main settings document used by the simplified beta config layer
EQUITY_LAKE_CONFIG_PATH=config/settings.yaml

# Optional overrides for GitHub Actions / local dashboard export
EQUITY_LAKE_DASHBOARD_OUTPUT_DIR=site
EQUITY_LAKE_SCHEDULE_CRON=0 1 * * 1-5
EQUITY_LAKE_SCHEDULE_TIMEZONE=Asia/Singapore

# =============================================================================
# FRED API Configuration (for macro indicators)
# =============================================================================
# Register for free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Finnhub news and social sentiment
FINNHUB_API_KEY=

# Reddit sentiment loader (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=equity-lake/0.1 (by u/your_reddit_username)

# SEC loader identity (optional but recommended)
SEC_USER_AGENT=Equity Lake contact@example.com

# =============================================================================
# Macro Indicators Configuration (for gold ETF analysis)
# =============================================================================
# Enable macro indicators fetching
ENABLE_MACRO_INDICATORS=true

# Comma-separated list of indicators to fetch:
# dxy, treasury_10y, tips_yield, breakeven_inflation, vix,
# gld, iau, policy_uncertainty
MACRO_INDICATORS=dxy,treasury_10y,tips_yield,breakeven_inflation,vix,gld,iau,policy_uncertainty
