# Equity Lake environment template
# Copy to `.env` and fill only the values you need.
#
# Settings are loaded from config/settings.yaml first, then overridden by
# environment variables using the EQUITY_ prefix with __ as nested delimiter.
# Priority: init args > env vars > .env file > config/settings.yaml defaults
#
# Examples:
#   EQUITY_STORAGE__DATA_DIR=data
#   EQUITY_SCHEDULE__CRON=0 1 * * 1-5
#   EQUITY_DASHBOARD__TITLE=Equity Lake

# =============================================================================
# Project
# =============================================================================
EQUITY_PROJECT__ENVIRONMENT=development

# =============================================================================
# Storage overrides
# =============================================================================
EQUITY_STORAGE__DATA_DIR=data
EQUITY_STORAGE__DB_PATH=equity_data.duckdb

# =============================================================================
# Schedule overrides
# =============================================================================
EQUITY_SCHEDULE__CRON=0 1 * * 1-5
EQUITY_SCHEDULE__TIMEZONE=Asia/Singapore

# =============================================================================
# Dashboard overrides
# =============================================================================
EQUITY_DASHBOARD__OUTPUT_DIR=site

# =============================================================================
# S3-compatible object storage bootstrap
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=s3://your-bucket/path/

R2_ACCOUNT_ID=
R2_BUCKET=
R2_ENDPOINT=

# =============================================================================
# Market / macro APIs
# =============================================================================
FRED_API_KEY=

# =============================================================================
# Finnhub news + social sentiment
# =============================================================================
FINNHUB_API_KEY=

# =============================================================================
# Reddit sentiment loader
# =============================================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=equity-lake/0.1 (by u/your_reddit_username)

# =============================================================================
# SEC loader identity
# =============================================================================
SEC_USER_AGENT=Equity Lake contact@example.com

# =============================================================================
# Macro toggles
# =============================================================================
ENABLE_MACRO_INDICATORS=true
MACRO_INDICATORS=dxy,treasury_10y,tips_yield,breakeven_inflation,vix,gld,iau,policy_uncertainty
