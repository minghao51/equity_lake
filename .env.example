# Equity Lake environment template
# Copy to `.env` and fill only the values you need.

# =============================================================================
# Core settings
# =============================================================================
EQUITY_LAKE_CONFIG_PATH=config/settings.yaml
EQUITY_LAKE_DASHBOARD_OUTPUT_DIR=site
EQUITY_LAKE_SCHEDULE_CRON=0 1 * * 1-5
EQUITY_LAKE_SCHEDULE_TIMEZONE=Asia/Singapore

# Optional runtime overrides for legacy-compatible paths
DB_PATH=equity_data.duckdb
DATA_DIR=data
LOG_DIR=logs
LOG_LEVEL=INFO
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=1.0
DEV_MODE=false
USE_TEST_DATA=false

# =============================================================================
# Optional AWS / S3 bootstrap
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=s3://your-bucket/path/

# =============================================================================
# Optional market / macro APIs
# =============================================================================
# FRED macro indicators
FRED_API_KEY=

# Finnhub news + social sentiment
FINNHUB_API_KEY=

# =============================================================================
# Optional Reddit sentiment loader
# =============================================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=equity-lake/0.1 (by u/your_reddit_username)

# =============================================================================
# Optional SEC loader identity
# =============================================================================
# SEC requests should send a descriptive user agent with contact info
SEC_USER_AGENT=Equity Lake contact@example.com

# =============================================================================
# Optional macro toggles
# =============================================================================
ENABLE_MACRO_INDICATORS=true
MACRO_INDICATORS=dxy,treasury_10y,tips_yield,breakeven_inflation,vix,gld,iau,policy_uncertainty
