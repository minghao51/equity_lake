# Equity EOD Data Pipeline - Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# S3 Configuration (Optional - for public buckets, leave empty)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# S3 bucket containing historical US equity data
# Example: s3://us-equity-ohlc-parquet/
S3_BUCKET=

# ============================================================================
# Database Configuration
# ============================================================================
# DuckDB database file path (relative to project root)
DB_PATH=equity_data.duckdb

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory path
LOG_DIR=logs

# ============================================================================
# API Configuration
# ============================================================================
# Rate limiting for API calls (requests per second)
YFINANCE_RATE_LIMIT=2.0
AKSHARE_RATE_LIMIT=1.0

# API timeout in seconds
API_TIMEOUT=30

# ============================================================================
# Data Configuration
# ============================================================================
# Data directory path
DATA_DIR=data

# Cache directory for temporary files
CACHE_DIR=.cache

# Number of parallel workers for data processing
MAX_WORKERS=4

# ============================================================================
# Market Configuration
# ============================================================================
# Comma-separated list of markets to ingest: us,cn,hk,sg
MARKETS=us,cn,hk,sg

# ============================================================================
# Ticker Configuration (NEW)
# ============================================================================
# Path to ticker configuration YAML file
# If empty, uses default: config/tickers.yaml
TICKER_CONFIG_PATH=config/tickers.yaml

# Default ticker filters (optional, applied when using config)
# These can be overridden by CLI arguments
#
# Filter by tags (comma-separated)
# Example: DEFAULT_TAGS=blue-chip,S&P 500
DEFAULT_TAGS=

# Filter by sectors (comma-separated)
# Example: DEFAULT_SECTORS=Technology,Finance,Healthcare
DEFAULT_SECTORS=

# Minimum priority level (1-10, higher = more important)
# Example: DEFAULT_MIN_PRIORITY=8
DEFAULT_MIN_PRIORITY=

# Exclude tickers with these tags (comma-separated)
# Example: EXCLUDE_TAGS=penny-stock,small-cap
EXCLUDE_TAGS=

# ============================================================================
# Legacy Configuration (DEPRECATED - Use config/tickers.yaml instead)
# ============================================================================
# US stock tickers to monitor (comma-separated, or 'ALL' for all)
# DEPRECATED: Use TICKER_CONFIG_PATH and filter with --tags CLI flag
US_TICKERS=AAPL,GOOGL,MSFT,AMZN,TSLA,NVDA,META,BRK-A,JNJ,JPM

# China A-share stock codes (comma-separated, or 'MAJOR' for major stocks)
# DEPRECATED: Use TICKER_CONFIG_PATH and filter with --tags CLI flag
CN_TICKERS=MAJOR

# Hong Kong stock tickers (comma-separated)
# DEPRECATED: Use TICKER_CONFIG_PATH and filter with --tags CLI flag
HK_TICKERS=0700,9988,1299,2318,0941,1398,0388,0005

# Singapore stock tickers (comma-separated)
# DEPRECATED: Use TICKER_CONFIG_PATH and filter with --tags CLI flag
SG_TICKERS=D05,O39,U11,Z74,BN4,S68

# ============================================================================
# Development Configuration
# ============================================================================
# Set to 'true' to enable development mode (more verbose logging)
DEV_MODE=false

# Set to 'true' to skip actual API calls and use test data
USE_TEST_DATA=false

# Number of days to keep in logs
LOG_RETENTION_DAYS=30

# ============================================================================
# Docker Configuration (Optional)
# ============================================================================
# Docker image tag
DOCKER_TAG=equity-eod:latest

# Docker registry (if pushing to a registry)
DOCKER_REGISTRY=

# ============================================================================
# Monitoring Configuration (Optional)
# ============================================================================
# Slack webhook for notifications (optional)
SLACK_WEBHOOK=

# Email for error notifications (optional)
NOTIFICATION_EMAIL=

# Health check URL (optional)
HEALTH_CHECK_URL=